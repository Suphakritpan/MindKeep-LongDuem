# MindKeep — environment template (copy to infra/.env, fill real values, never commit .env)

# ── Database (PostgreSQL + pgvector) ──────────────────────────
POSTGRES_USER=mindkeep
POSTGRES_PASSWORD=change_me
POSTGRES_DB=mindkeep
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://mindkeep:change_me@db:5432/mindkeep

# ── Backend API ───────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8080
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRE_MINUTES=720

# ── Local AI (Ollama) ─────────────────────────────────────────
# local-first: internal company data must NOT go to external AI by default
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b
EMBEDDING_MODEL=nomic-embed-text

# ── Storage (StorageService) ──────────────────────────────────
# local filesystem first; keep real uploads under private/ (gitignored)
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./private/uploads

# ── Frontend ──────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1
